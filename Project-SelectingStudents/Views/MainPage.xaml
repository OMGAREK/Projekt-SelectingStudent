<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 x:Class="Project_SelectingStudents.Views.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Frame>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Manage Classes" StyleClass="section-title" />
                    <HorizontalStackLayout Spacing="8">
                        <Entry x:Name="NewClassEntry" Placeholder="Class name" />
                        <Button Text="Add Class" Clicked="OnCreateClassClicked" />
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding Classes}" SelectionMode="Single" x:Name="ClassesCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding Name}" Padding="8" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Manage Students" StyleClass="section-title" />
                    <Picker ItemsSource="{Binding Classes}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedClass}" Title="Select class" />

                    <HorizontalStackLayout Spacing="8">
                        <Entry x:Name="NewStudentEntry" Placeholder="Student name" />
                        <Button Text="Add" Clicked="OnAddStudentClicked" />
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding Students}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Padding="8" Spacing="8">
                                    <Label Text="{Binding Id, StringFormat='#{0}'}" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" />
                                    <Label Text="{Binding Name}" VerticalOptions="Center" />
                                    <CheckBox IsChecked="{Binding IsPresent}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Save" Clicked="OnSaveClicked" />
                        <Button Text="Delete Class" Clicked="OnDeleteClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Draw Student" StyleClass="section-title" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Draw" Clicked="OnDrawClicked" />
                        <Button Text="Assign Lucky" Clicked="OnAssignLuckyClicked" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding Result}" StyleClass="result-text" />
                    <Label Text="{Binding LuckyResult}" StyleClass="result-text" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>