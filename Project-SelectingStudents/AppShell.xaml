<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Project_SelectingStudents.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Project_SelectingStudents"
    xmlns:views="clr-namespace:Project_SelectingStudents.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Selecting Students">

    <Shell.TitleView>
        <Label Text="Selection System" VerticalTextAlignment="Center" />
    </Shell.TitleView>

    <ShellContent
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

</Shell>
